<div class="max-w-7xl mx-auto p-6 text-slate-100">

  <h1 class="text-3xl font-bold mb-6 text-emerald-400">
    Painel Administrativo
  </h1>

  <!-- NOVO VENDEDOR -->
  <div class="bg-slate-900 p-6 rounded-xl mb-6">

    <h2 class="text-xl font-semibold mb-4">
      Novo Vendedor
    </h2>

    <form action="/vendedor" method="POST">

      <div class="grid md:grid-cols-3 gap-4">

        <input
          name="nome"
          placeholder="Nome do vendedor"
          required
          class="p-3 rounded bg-slate-800">

        <input
          name="percentual"
          type="number"
          step="0.1"
          placeholder="% comissão"
          required
          class="p-3 rounded bg-slate-800">

        <button
          type="submit"
          class="bg-emerald-600 hover:bg-emerald-700 rounded">

          Adicionar

        </button>

      </div>

    </form>

  </div>

  <div class="grid md:grid-cols-2 gap-6">

    <!-- VENDEDORES -->
    <div class="bg-slate-900 p-6 rounded-xl">

      <h2 class="text-xl font-semibold mb-4">
        Vendedores
      </h2>

      <table class="w-full">

        <thead>
          <tr class="text-slate-400 text-sm border-b border-slate-800">
            <th class="text-left pb-2">Nome</th>
            <th class="text-left pb-2">%</th>
            <th class="text-right pb-2">Ações</th>
          </tr>
        </thead>

        <tbody>

          <% @vendedores.each do |v| %>

            <tr class="border-b border-slate-800/50">

              <td class="py-3">

                <%= v[:nome] %>

                <% if v[:ativo] == 1 %>
                  <span class="text-emerald-400 text-xs">
                    (Ativo)
                  </span>
                <% else %>
                  <span class="text-red-400 text-xs">
                    (Inativo)
                  </span>
                <% end %>

              </td>

              <td>
                <%= v[:percentual] %>%
              </td>

              <td class="py-3">

                <form
                  action="/vendedor/percentual"
                  method="POST"
                  class="flex gap-2 mb-2">

                  <input
                    type="hidden"
                    name="id"
                    value="<%= v[:id] %>">

                  <input
                    type="number"
                    step="0.1"
                    name="percentual"
                    value="<%= v[:percentual] %>"
                    class="bg-slate-800 p-1 rounded w-20 text-center">

                  <button
                    type="submit"
                    class="bg-blue-600 px-3 py-1 rounded">

                    Salvar

                  </button>

                </form>

                <% if v[:ativo] == 1 %>

                  <form
                    action="/vendedor/desativar/<%= v[:id] %>"
                    method="POST">

                    <button
                      class="bg-red-600 px-3 py-1 rounded w-full">

                      Desativar

                    </button>

                  </form>

                <% else %>

                  <form
                    action="/vendedor/ativar/<%= v[:id] %>"
                    method="POST">

                    <button
                      class="bg-emerald-600 px-3 py-1 rounded w-full">

                      Ativar

                    </button>

                  </form>

                <% end %>

              </td>

            </tr>

          <% end %>

        </tbody>

      </table>

    </div>

    <!-- ÚLTIMAS VENDAS -->
    <div class="bg-slate-900 p-6 rounded-xl">

      <h2 class="text-xl font-semibold mb-4">
        Últimas Vendas
      </h2>

      <table class="w-full">

        <thead>
          <tr class="text-slate-400 text-sm border-b border-slate-800">
            <th class="text-left pb-2">Vendedor</th>
            <th class="text-left pb-2">Produto</th>
            <th class="text-right pb-2">Ação</th>
          </tr>
        </thead>

        <tbody>

          <% @vendas.each do |v| %>

            <tr class="border-b border-slate-800/50">

              <td class="py-3">
                <%= v[:nome] %>
              </td>

              <td class="py-3">
                <%= v[:produto] %>
              </td>

              <td class="py-3 text-right">

                <form
                  action="/venda/excluir/<%= v[:id] %>"
                  method="POST">

                  <button
                    type="submit"
                    class="bg-red-600 hover:bg-red-700 px-3 py-1 rounded"
                    onclick="return confirm('Deseja excluir esta venda?')">

                    Excluir

                  </button>

                </form>

              </td>

            </tr>

          <% end %>

        </tbody>

      </table>

    </div>

  </div>

  <!-- META -->
  <div class="bg-slate-900 p-6 rounded-xl mt-6">

    <h2 class="text-xl font-semibold mb-4">
      Meta Mensal
    </h2>

    <form action="/meta" method="POST" class="max-w-md">

      <div class="flex gap-4">

        <input
          name="valor"
          type="number"
          step="0.01"
          value="<%= (@meta && @meta[:valor]) || 100000 %>"
          class="flex-1 p-3 rounded bg-slate-800">

        <button
          type="submit"
          class="bg-blue-600 px-6 py-3 rounded">

          Salvar Meta

        </button>

      </div>

    </form>

  </div>

</div>