<div class="max-w-7xl mx-auto p-6">

<h1 class="text-3xl font-bold mb-6 text-emerald-400">
Painel Administrativo
</h1>

<div class="grid md:grid-cols-2 gap-6">

<div class="bg-slate-900 p-6 rounded-xl">

<h2 class="text-xl mb-4">
Vendedores
</h2>

<table class="w-full">

<thead>
<tr>
<th class="text-left">Nome</th>
<th>%</th>
<th>Ação</th>
</tr>
</thead>

<tbody>

<% @vendedores.each do |v| %>

<tr class="border-t border-slate-800">

<td><%= v[:nome] %></td>

<td><%= v[:percentual] %>%</td>

<td>

<form
action="/vendedor/percentual"
method="POST"
class="flex gap-2">

<input
type="hidden"
name="id"
value="<%= v[:id] %>">

<input
name="percentual"
value="<%= v[:percentual] %>"
class="bg-slate-800 p-2 rounded w-20">

<button
class="bg-blue-600 px-3 rounded">

Salvar

</button>

</form>

</td>

</tr>

<% end %>

</tbody>

</table>

</div>

<div class="bg-slate-900 p-6 rounded-xl">

<h2 class="text-xl mb-4">
Últimas Vendas
</h2>

<table class="w-full">

<thead>
<tr>
<th>Vendedor</th>
<th>Produto</th>
<th>Ação</th>
</tr>
</thead>

<tbody>

<% @vendas.each do |v| %>

<tr class="border-t border-slate-800">

<td><%= v[:nome] %></td>

<td><%= v[:produto] %></td>

<td>

<a
href="/venda/excluir/<%= v[:id] %>"
class="bg-red-600 px-3 py-1 rounded">

Excluir

</a>

</td>

</tr>

<% end %>

</tbody>

</table>

</div>

</div>

</div>

<div class="bg-slate-900 p-6 rounded-xl mt-6">

<h2 class="text-xl mb-4">
Meta Mensal
</h2>

<form action="/meta" method="POST">

<input
name="valor"
type="number"
step="0.01"
value="<%= @meta ? @meta[:valor] : 100000 %>"
class="w-full p-3 rounded bg-slate-800 mb-4">

<button
class="bg-blue-600 px-4 py-2 rounded">

Salvar Meta

</button>

</form>

</div>