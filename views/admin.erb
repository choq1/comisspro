<div class="max-w-7xl mx-auto p-6 text-slate-100">

  <h1 class="text-3xl font-bold mb-6 text-emerald-400">
    Painel Administrativo
  </h1>

  <div class="grid md:grid-cols-2 gap-6">

    <!-- Bloco de Vendedores -->
    <div class="bg-slate-900 p-6 rounded-xl">
      <h2 class="text-xl font-semibold mb-4">Vendedores</h2>
      <table class="w-full">
        <thead>
          <tr class="text-slate-400 text-sm border-b border-slate-800">
            <th class="text-left pb-2">Nome</th>
            <th class="text-left pb-2 w-24">%</th>
            <th class="text-right pb-2">Ação</th>
          </tr>
        </thead>
        <tbody>
          <% @vendedores.each do |v| %>
            <tr class="border-b border-slate-800/50 last:border-0">
              <td class="py-3 text-left"><%= v[:nome] %></td>
              <td class="py-3 text-left"><%= v[:percentual] %>%</td>
              <td class="py-3">
                <form action="/vendedor/percentual" method="POST" class="flex justify-end gap-2">
                  <input type="hidden" name="id" value="<%= v[:id] %>">
                  <input type="number" name="percentual" value="<%= v[:percentual] %>" class="bg-slate-800 p-1.5 rounded w-16 text-center text-sm">
                  <button type="submit" class="bg-blue-600 hover:bg-blue-700 px-3 py-1.5 rounded text-sm font-medium transition">
                    Salvar
                  </button>
                </form>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Bloco de Últimas Vendas -->
    <div class="bg-slate-900 p-6 rounded-xl">
      <h2 class="text-xl font-semibold mb-4">Últimas Vendas</h2>
      <table class="w-full">
        <thead>
          <tr class="text-slate-400 text-sm border-b border-slate-800">
            <th class="text-left pb-2">Vendedor</th>
            <th class="text-left pb-2">Produto</th>
            <th class="text-right pb-2">Ação</th>
          </tr>
        </thead>
        <tbody>
          <% @vendas.each do |v| %>
            <tr class="border-b border-slate-800/50 last:border-0">
              <td class="py-3 text-left"><%= v[:nome] %></td>
              <td class="py-3 text-left"><%= v[:produto] %></td>
              <td class="py-3 text-right">
                <!-- Correção de Segurança: Alterado de Link para Formulário POST -->
                <form action="/venda/excluir/<%= v[:id] %>" method="POST" class="inline">
                  <button type="submit" class="bg-red-600 hover:bg-red-700 px-3 py-1.5 rounded text-sm font-medium transition" onclick="return confirm('Tem certeza que deseja excluir esta venda?')">
                    Excluir
                  </button>
                </form>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  </div>

  <!-- Bloco de Meta Mensal -->
  <div class="bg-slate-900 p-6 rounded-xl mt-6">
    <h2 class="text-xl font-semibold mb-4">Meta Mensal</h2>
    <form action="/meta" method="POST" class="max-w-md">
      <div class="flex gap-4">
        <input name="valor" type="number" step="0.01" value="<%= (@meta && @meta[:valor]) || 100000 %>" class="flex-1 p-3 rounded bg-slate-800 border border-slate-700 focus:outline-none focus:border-emerald-400">
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded font-medium transition whitespace-nowrap">
          Salvar Meta
        </button>
      </div>
    </form>
  </div>

</div>
